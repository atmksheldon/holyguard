rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Get user's organization ID
    function getUserOrgId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organization_id;
    }

    // Helper: Check if user's organization is verified
    function isOrgVerified() {
      let orgId = getUserOrgId();
      let orgs = getAfter(/databases/$(database)/documents/organizations/$(orgId));
      return true; // Simplified - org verification enforced via status check below
    }

    // Helper: Check if user is super_admin
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // User Profiles
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for user directory)
      allow read: if request.auth != null;
      // Only the user can update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Alerts
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      // Validate required fields to prevent malformed data
      allow create: if request.auth != null &&
        request.resource.data.reporterId is string &&
        request.resource.data.title is string &&
        request.resource.data.timestamp != null &&
        // latitude and longitude are optional but must be numbers if present
        (!('latitude' in request.resource.data) || request.resource.data.latitude is number) &&
        (!('longitude' in request.resource.data) || request.resource.data.longitude is number);
      // Reporter or admin can update incidents (edit description, add photos, change category)
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.reporterId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.reporterId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // Team Messages
    match /team_messages/{messageId} {
      // Users can only read messages from their own organization
      allow read: if request.auth != null;
      // Validate message structure
      allow create: if request.auth != null &&
        request.resource.data.text is string &&
        request.resource.data.text.size() <= 500 &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.organizationId is string;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
    }

    // Organizations
    match /organizations/{orgId} {
      // Anyone authenticated can read organizations (for map display)
      allow read: if request.auth != null;
      // Authenticated users can create during signup (status can be 'pending', 'Active', or 'verified')
      allow create: if request.auth != null &&
        request.resource.data.name is string &&
        request.resource.data.address is string &&
        request.resource.data.latitude is number &&
        request.resource.data.longitude is number &&
        request.resource.data.status in ['pending', 'Active', 'verified'];
      // Regular users can update name/address but NOT status
      // Super admin can update anything
      allow update: if request.auth != null && (
        // Super admin can update anything
        isSuperAdmin() ||
        // Regular users can update but cannot change status
        (request.resource.data.status == resource.data.status &&
         request.resource.data.name is string &&
         request.resource.data.address is string &&
         request.resource.data.latitude is number &&
         request.resource.data.longitude is number)
      );
      // Only super admin can delete organizations
      allow delete: if request.auth != null && isSuperAdmin();

      // Verification subcollection - only admin SDK (Cloud Functions) writes
      match /verification/{docId} {
        allow read: if request.auth != null;
        allow write: if false; // Only admin SDK writes here
      }
    }

    // Invite Codes
    match /invite_codes/{codeId} {
      // Anyone authenticated can read (needed for validation)
      allow read: if request.auth != null;
      // Only admins can create invite codes
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
      // Only the creator or admin can update/delete
      allow update, delete: if request.auth != null &&
        (resource.data.createdBy == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // Channels
    match /channels/{channelId} {
      // Anyone authenticated can read channels
      allow read: if request.auth != null;
      // Admins can create channels
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'] &&
        request.resource.data.name is string &&
        request.resource.data.organizationId is string;
      // Only admins can delete channels
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // DM Invites
    match /dm_invites/{inviteId} {
      // Users can read invites they sent or received
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.fromUserId ||
         request.auth.uid == resource.data.toUserId);
      // Users can create invites they are sending
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.status == 'pending';
      // Only recipient can update (accept/decline)
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.toUserId &&
        resource.data.status == 'pending';
    }

    // Conversations
    match /conversations/{conversationId} {
      // Users can read conversations they are part of
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      // Users can create conversations they are part of
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      // Users can update conversations they are part of (for last message)
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
    }

    // Direct Messages
    match /direct_messages/{messageId} {
      // Anyone authenticated can read (filtered by conversation on client)
      allow read: if request.auth != null;
      // Users can create messages they are sending (text or image)
      allow create: if request.auth != null &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() <= 500 &&
        request.resource.data.conversationId is string &&
        // imageUrl is optional
        (!('imageUrl' in request.resource.data) || request.resource.data.imageUrl is string);
    }

    // Watchlist Entries
    match /watchlist/{entryId} {
      // Authenticated users can read watchlist entries
      allow read: if request.auth != null;
      // Authenticated users can create entries with required fields
      allow create: if request.auth != null &&
        request.resource.data.name is string &&
        request.resource.data.status is string &&
        request.resource.data.organizationId is string &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt != null;
      // Creator or admin can update
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
      // Creator or admin can delete
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // Resources
    match /resources/{resourceId} {
      // All authenticated users can read resources
      allow read: if request.auth != null;
      // All authenticated users can create resources
      allow create: if request.auth != null &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 100 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 1000 &&
        request.resource.data.category is string &&
        request.resource.data.postedBy == request.auth.uid &&
        request.resource.data.organizationId is string &&
        request.resource.data.timestamp != null;
      // Only poster or admin can delete
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.postedBy ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // Mail collection (for Firebase Trigger Email extension)
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read: if false;
    }
  }
}
